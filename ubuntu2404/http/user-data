#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  timezone: UTC
  refresh-installer:
    update: false
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
  packages:
    - build-essential
    - cryptsetup
    - curl
    - dkms
    - linux-headers-generic
    - nfs-common
    - vim
    - wget
    - zlib1g-dev
  identity:
    hostname: ubuntu2404
    username: vagrant
    password: "$6$NofkfMs0DXCjLl2L$ipq.zTzqfSgyI82ioW9KBewJVJTPJRUwRTg919DLqZX9cLu3h99b/qL4WwhwRbJUE9LWQ13YA37tBOyEdzPNb0"
  late-commands:
    - [curtin, in-target, --, mkdir, -p, /etc/sudoers.d]
    - [curtin, in-target, --, bash, -c, "printf 'vagrant ALL=(ALL) NOPASSWD: ALL\n' > /etc/sudoers.d/vagrant"]
    - [curtin, in-target, --, chmod, "0440", /etc/sudoers.d/vagrant]
    - [curtin, in-target, --, mkdir, -p, /etc/ssh/sshd_config.d]
    - [curtin, in-target, --, bash, -c, "printf 'PasswordAuthentication yes\n' > /etc/ssh/sshd_config.d/99-packer.conf"]
